# ==============================================================================
# CONFIGURACIÓN DEL SERVIDOR API
# ==============================================================================
PORT=3000
NODE_ENV=development
CORS_ORIGIN=*

# ==============================================================================
# CONEXIÓN A BASE DE DATOS MYSQL
# ==============================================================================
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=root_password
DB_NAME=bd_financiera_confianza
DB_CONNECTION_LIMIT=10

# ==============================================================================
# AUTENTICACIÓN JWT Y PROVEEDOR DE IDENTIDAD (OIDC)
# ==============================================================================
# URI de las llaves públicas de firma del IDP (Dokploy/Keycloak/Auth0)
JWKS_URI=https://[TU_DOMINIO_DOKPLOY]/realms/banco-singular/protocol/openid-connect/certs
JWT_AUDIENCE=account
JWT_ISSUER=https://[TU_DOMINIO_DOKPLOY]/realms/banco-singular

# Opción 1: Ignorar autenticación (solo para desarrollo local rápido)
BYPASS_AUTH=false

# Opción 2: Validar tokens firmados con una llave de desarrollo HS256 local
USE_DEV_SECRET=true
JWT_DEV_SECRET=super-secret-development-key-for-local-testing

# ==============================================================================
# CONFIGURACIÓN DE REDIS (CACHÉ)
# ==============================================================================
# URI de conexión a Redis. Si no se especifica, se usará caché en memoria (fallback)
REDIS_URL=redis://default:password@host:6379
